# Space-separated list of hostnames clients use to reach Nextcloud. The
# Nextcloud official image refuses requests for any host not listed here. For
# multi-device dev (Tailscale, LAN, mDNS) include every name you'll hit:
#   NEXTCLOUD_TRUSTED_DOMAINS="localhost 192.168.1.42 macbook.tail-scale.ts.net"
# Defaults to "localhost" when unset.
NEXTCLOUD_TRUSTED_DOMAINS=

# Protocol Nextcloud should report in generated URLs. Defaults to "http" so
# local development without TLS works out of the box. Set to "https" if you
# terminate TLS in front of the container.
OVERWRITEPROTOCOL=
